{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TikTok Desktop",
  "version": "1.0.0",
  "identifier": "com.crtypubg.tiktok_desktop_app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TikTok Desktop",
        "width": 450,
        "height": 800,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../images/icon-app-tt.ico",
      "../images/tt-icon-app.png"
    ]
  }
}
